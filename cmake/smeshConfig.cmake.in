@PACKAGE_INIT@

include(CMakeFindDependencyMacro)

if(@SMESH_ENABLE_MPI@)
    if(NOT CMAKE_C_COMPILER_LOADED)
        include(CheckLanguage)
        check_language(C)
        if(NOT CMAKE_C_COMPILER)
            set(smesh_FOUND FALSE)
            set(smesh_NOT_FOUND_MESSAGE
                "smesh MPI support requires the C language because matrixio exports MPI::MPI_C, but no C compiler is available.")
            return()
        endif()
        enable_language(C)
    endif()

    find_dependency(MPI COMPONENTS C CXX)

    set(_smesh_matrixio_dir "${PACKAGE_PREFIX_DIR}/@CMAKE_INSTALL_LIBDIR@/cmake/matrixio")
    if(NOT DEFINED matrixio_DIR AND EXISTS "${_smesh_matrixio_dir}/matrixioConfig.cmake")
        set(_smesh_restore_matrixio_dir FALSE)
        set(matrixio_DIR "${_smesh_matrixio_dir}")
    else()
        set(_smesh_restore_matrixio_dir TRUE)
    endif()

    find_dependency(matrixio CONFIG)

    if(NOT _smesh_restore_matrixio_dir)
        unset(matrixio_DIR)
    endif()
    unset(_smesh_restore_matrixio_dir)
    unset(_smesh_matrixio_dir)
endif()

if(@SMESH_ENABLE_OPENMP@)
    find_dependency(OpenMP COMPONENTS C CXX)
endif()

if(@SMESH_PACKAGE_NEEDS_BLAS@)
    find_dependency(BLAS)
endif()

if(@SMESH_ENABLE_LAPACK@)
    find_dependency(LAPACK)
endif()

include("${CMAKE_CURRENT_LIST_DIR}/smeshTargets.cmake")

check_required_components(smesh)
