#define SMESH_CUDA_MEMORY_MODEL @SMESH_CUDA_MEMORY_MODEL@

#define SMESH_LOG_LEVEL @SMESH_LOG_LEVEL@

#define SMESH_WARP_SIZE 32
#define SMESH_WARP_FULL_MASK 0xffffffff

#ifdef SMESH_ENABLE_CUDA

// To enable atomicOr we need int
typedef int mask_t;
#define SMESH_MPI_MASK_T MPI_INT
#define SMESH_PTRDIFF_INVALID -1

#else

typedef char mask_t;
#define SMESH_MPI_MASK_T MPI_CHAR
#define SMESH_PTRDIFF_INVALID -1

#endif // SMESH_ENABLE_CUDA

#if defined(__APPLE__)
typedef __fp16 half_t;
#else
typedef _Float16 half_t;
#endif
