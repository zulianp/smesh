#cmakedefine01 SMESH_PRINT_THROUGHPUT

#ifdef SMESH_ENABLE_CUDA
#define SMESH_CUDA_ARCH @SMESH_CUDA_ARCH@
#endif

#define CUDA_UNIFIED_MEMORY 0
#define CUDA_MANAGED_MEMORY 1
#define CUDA_HOST_MEMORY 2

#include <stdint.h>
#include <stdlib.h>

// -----------------------------
// Floating point representation
// -----------------------------

namespace smesh {

// geometric quantities / mesh
typedef @SMESH_GEOM_C_TYPE@ geom_t;
#define SMESH_MPI_GEOM_T @SMESH_GEOM_MPI_TYPE@
#define SMESH_CUSPARSE_GEOM_T @SMESH_GEOM_CUSPARSE_TYPE@
#define d_GEOM_T "@SMESH_GEOM_PRINT_TYPE@"
#define dtype_GEOM_T "@SMESH_GEOM_TYPE@"

// real numbers
typedef @SMESH_REAL_C_TYPE@ real_t;
#define SMESH_MPI_REAL_T @SMESH_REAL_MPI_TYPE@
#define SMESH_CUSPARSE_REAL_T @SMESH_REAL_CUSPARSE_TYPE@
#define d_REAL_T "@SMESH_REAL_PRINT_TYPE@"
#define dtype_REAL_T "@SMESH_REAL_TYPE@"
#define SIZEOF_REAL_T @SMESH_SIZEOF_REAL_T@

#define SMESH_REAL_T_IS_FLOAT64 (SIZEOF_REAL_T == 8)
#define SMESH_REAL_T_IS_FLOAT32 (SIZEOF_REAL_T == 4)

// computation real numbers and explicit vectorized types
typedef @SMESH_SCALAR_C_TYPE@ scalar_t;
#define SMESH_MPI_SCALAR_T @SMESH_SCALAR_MPI_TYPE@
#define SMESH_CUSPARSE_SCALAR_T @SMESH_SCALAR_CUSPARSE_TYPE@
#define d_SCALAR_T "@SMESH_SCALAR_PRINT_TYPE@"
#define dtype_SCALAR_T "@SMESH_SCALAR_TYPE@"

#ifndef _WIN32
#define SMESH_VEC_SIZE @SMESH_VEC_SIZE@
typedef scalar_t vec_t __attribute__((vector_size(SMESH_VEC_SIZE * sizeof(scalar_t)),
                                      aligned(SMESH_VEC_SIZE * sizeof(scalar_t))));
#else
#define SMESH_VEC_SIZE 1
typedef scalar_t vec_t;
#endif
// Jacobian
typedef @SMESH_JACOBIAN_CPU_C_TYPE@ jacobian_t;
#define SMESH_MPI_JACOBIAN_CPU_T @SMESH_JACOBIAN_CPU_MPI_TYPE@
#define SMESH_CUSPARSE_JACOBIAN_CPU_T @SMESH_JACOBIAN_CPU_CUSPARSE_TYPE@
#define d_JACOBIAN_CPU_T "@SMESH_JACOBIAN_CPU_PRINT_TYPE@"
#define dtype_JACOBIAN_CPU_T "@SMESH_JACOBIAN_CPU_TYPE@"

// Jacobian (GPU)
#define cu_jacobian_t @SMESH_JACOBIAN_GPU_TYPE@

// Accumulator for local kernels (before local to global)
typedef @SMESH_ACCUMULATOR_C_TYPE@ accumulator_t;
#define SMESH_MPI_ACCUMULATOR_T @SMESH_ACCUMULATOR_MPI_TYPE@
#define SMESH_CUSPARSE_ACCUMULATOR_T @SMESH_ACCUMULATOR_CUSPARSE_TYPE@
#define d_ACCUMULATOR_T "@SMESH_ACCUMULATOR_PRINT_TYPE@"
#define dtype_ACCUMULATOR_T "@SMESH_ACCUMULATOR_TYPE@"

// -----------------------------
// Indexing representation
// -----------------------------

// node / dof indices
typedef @SMESH_IDX_C_TYPE@ idx_t;
#define SMESH_MPI_IDX_T @SMESH_IDX_MPI_TYPE@
#define SMESH_CUSPARSE_IDX_T @SMESH_IDX_CUSPARSE_TYPE@
#define d_IDX_T "@SMESH_IDX_PRINT_TYPE@"
#define dtype_IDX_T "@SMESH_IDX_TYPE@"
#define SMESH_IDX_INVALID @SMESH_IDX_INVALID@

// nnz count
typedef @SMESH_COUNT_C_TYPE@ count_t;
#define SMESH_MPI_COUNT_T @SMESH_COUNT_MPI_TYPE@
#define SMESH_CUSPARSE_COUNT_T @SMESH_COUNT_CUSPARSE_TYPE@
#define d_COUNT_T "@SMESH_COUNT_PRINT_TYPE@"
#define dtype_COUNT_T "@SMESH_COUNT_TYPE@"
#define SMESH_COUNT_INVALID @SMESH_COUNT_INVALID@

// element ids
typedef @SMESH_ELEMENT_IDX_C_TYPE@ element_idx_t;
#define SMESH_MPI_ELEMENT_IDX_T @SMESH_ELEMENT_IDX_MPI_TYPE@
#define SMESH_CUSPARSE_ELEMENT_IDX_T @SMESH_ELEMENT_IDX_CUSPARSE_TYPE@
#define d_ELEMENT_IDX_T "@SMESH_ELEMENT_IDX_PRINT_TYPE@"
#define dtype_ELEMENT_IDX_T "@SMESH_ELEMENT_IDX_TYPE@"
#define SMESH_ELEMENT_IDX_INVALID @SMESH_ELEMENT_IDX_INVALID@

// Local ids for small block of elements (goal is 16 bits with max id 65'536)
typedef @SMESH_LOCAL_IDX_C_TYPE@ local_idx_t;
#define SMESH_MPI_LOCAL_IDX_T @SMESH_LOCAL_IDX_MPI_TYPE@
#define SMESH_CUSPARSE_LOCAL_IDX_T @SMESH_LOCAL_IDX_CUSPARSE_TYPE@
#define d_LOCAL_IDX_T "@SMESH_LOCAL_IDX_PRINT_TYPE@"
#define dtype_LOCAL_IDX_T "@SMESH_LOCAL_IDX_TYPE@"
#define SMESH_LOCAL_IDX_INVALID @SMESH_LOCAL_IDX_INVALID@

// -----------------------------
// Other types
#define SMESH_TET4_CUDA @SMESH_TET4_CUDA@
